# =============================================================================
# UniShield — Environment Configuration
# See docs/week1/api-keys-setup.md and docs/week1/local-dev-stack.md
# =============================================================================

# --- Database (Week 1 canonical: PostgreSQL via Docker) ---
# Quick dev without Docker: leave UNISHIELD_USE_POSTGRES unset (SQLite default)
# UNISHIELD_USE_POSTGRES=1
# POSTGRES_URI=postgresql+asyncpg://unishield:password@localhost:5432/unishield

# --- Week 1: Agent reasoning ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Week 1: Security data sources (see docs/week1/api-keys-setup.md) ---
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
NVD_API_KEY=
# Comma-separated OSINT/breach/paste feed URLs (at least one for Week 1)
OSINT_FEED_URLS=

# --- Infrastructure ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
ELASTICSEARCH_URL=http://localhost:9200

VAULT_ADDR=http://localhost:8200
VAULT_DEV_ROOT_TOKEN=
VAULT_TOKEN=

# --- SIEM (Week 7+) ---
SPLUNK_URL=
SPLUNK_TOKEN=
QRADAR_URL=
QRADAR_TOKEN=

# --- Auth ---
JWT_SECRET=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
AUTO_SEED=true
