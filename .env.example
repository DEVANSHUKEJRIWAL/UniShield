# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local dev WITHOUT Docker — use SQLite (default when unset below)
UNISHIELD_USE_SQLITE=1
# POSTGRES_URI=sqlite+aiosqlite:///./data/unishield.db

# With Docker — comment UNISHIELD_USE_SQLITE and use:
# POSTGRES_URI=postgresql+asyncpg://unishield:password@localhost:5432/unishield
POSTGRES_PASSWORD=password
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
ELASTICSEARCH_URL=http://localhost:9200

# Secrets
VAULT_ADDR=http://localhost:8200
VAULT_DEV_ROOT_TOKEN=
VAULT_TOKEN=

# Connectors (optional — mock if absent)
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
NVD_API_KEY=
SPLUNK_URL=
SPLUNK_TOKEN=

# Application
JWT_SECRET=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
AUTO_SEED=true
