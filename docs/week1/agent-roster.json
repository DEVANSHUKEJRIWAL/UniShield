{
  "version": "1.0.0",
  "framework": "OpenClaw",
  "output_schema": "packages.core.schemas.AgentFinding",
  "agents": [
    {
      "id": "orchestrator",
      "role": "Central task router — priority queues, multi-agent dispatch, result aggregation",
      "input": { "event": "object", "tenant_id": "string", "priority": "P0|P1|P2|P3" },
      "output": "AgentFinding | aggregated multi-agent summary",
      "tools": ["dispatch_agent", "aggregate_findings"],
      "redis_streams": { "tasks": "unishield:agent:orchestrator:tasks", "findings": "unishield:agent:orchestrator:findings" }
    },
    {
      "id": "dark-web-agent",
      "role": "Monitor dark web forums, paste sites, breach databases; credential exposure",
      "input": { "query": "string", "tenant_id": "string", "sources": "string[]" },
      "output": "BreachFinding",
      "tools": ["crawl_dark_web_feeds", "check_credential_exposure", "monitor_paste_sites", "detect_typosquatting", "lookup_threat_actor", "query_knowledge_graph"]
    },
    {
      "id": "source-code-agent",
      "role": "SAST, secret scanning, dependency vulnerability analysis",
      "input": { "repo_path": "string", "diff_text": "string", "tenant_id": "string" },
      "output": "CodeFinding",
      "tools": ["run_semgrep", "run_bandit", "scan_for_secrets", "scan_dependency_vulnerabilities", "analyse_diff_semantics"]
    },
    {
      "id": "insider-threat-agent",
      "role": "UEBA, anomalous access, privilege escalation detection",
      "input": { "user_id": "string", "events": "array", "tenant_id": "string" },
      "output": "AgentFinding",
      "tools": ["score_user_anomaly", "detect_anomalous_access", "check_privilege_escalation", "get_user_baseline", "retrieve_insider_patterns"]
    },
    {
      "id": "threat-intel-agent",
      "role": "External TI lookups — VT, Shodan, MITRE ATT&CK, IOC correlation",
      "input": { "indicator": "string", "ioc_list": "string", "tenant_id": "string" },
      "output": "AgentFinding",
      "tools": ["query_virustotal", "query_shodan", "lookup_mitre_attack", "search_threat_intel_corpus", "correlate_iocs"]
    },
    {
      "id": "vulnerability-agent",
      "role": "CVE lookup, CVSS scoring, patch prioritisation",
      "input": { "cve_id": "string", "cve_list": "string", "tenant_id": "string" },
      "output": "AgentFinding",
      "tools": ["lookup_cve", "score_exploitability", "prioritise_patches", "check_known_exploitation", "query_sbom_for_cve"]
    },
    {
      "id": "incident-response-agent",
      "role": "Playbook retrieval, triage, escalation, containment recommendations",
      "input": { "incident_type": "string", "incident_data": "object", "tenant_id": "string" },
      "output": "IRFinding",
      "tools": ["retrieve_playbook", "triage_incident", "generate_escalation_path", "suggest_containment_actions"]
    },
    {
      "id": "siem-analysis-agent",
      "role": "Log search, anomaly detection, alert correlation",
      "input": { "query": "string", "alert_list": "array", "tenant_id": "string" },
      "output": "AgentFinding",
      "tools": ["run_splunk_search", "detect_log_anomaly", "correlate_alerts", "query_elasticsearch"]
    },
    {
      "id": "network-security-agent",
      "role": "Port scan analysis, traffic anomalies, firewall recommendations",
      "input": { "nmap_output": "string", "flow_data": "string", "tenant_id": "string" },
      "output": "AgentFinding",
      "tools": ["analyse_port_scan_result", "detect_traffic_anomaly", "recommend_firewall_rules", "check_lateral_movement_indicators", "query_knowledge_graph"]
    },
    {
      "id": "compliance-agent",
      "role": "Control mapping (NIST, ISO, RBI, DPDP), gap identification, evidence packs",
      "input": { "finding_id": "string", "framework": "string", "client_id": "string" },
      "output": "AgentFinding",
      "tools": ["map_finding_to_controls", "assess_control_coverage", "identify_gaps", "generate_evidence_pack"]
    },
    {
      "id": "forensics-agent",
      "role": "IOC extraction, timeline reconstruction, artefact analysis",
      "input": { "text_or_log": "string", "incident_id": "string", "tenant_id": "string" },
      "output": "ForensicFinding",
      "tools": ["extract_iocs", "reconstruct_timeline", "analyse_artefact", "correlate_iocs_with_graph"]
    },
    {
      "id": "graph-query-agent",
      "role": "Neo4j attack paths, blast radius, NL-to-Cypher",
      "input": { "source_entity": "string", "natural_language_query": "string", "tenant_id": "string" },
      "output": "AgentFinding",
      "tools": ["traverse_attack_paths", "find_crown_jewels_reachable", "identify_chokepoints", "get_blast_radius", "nl_to_cypher"]
    },
    {
      "id": "reporting-agent",
      "role": "Executive summaries, compliance reports, PDF export",
      "input": { "client_id": "string", "period": "string", "audience": "board|ciso|analyst" },
      "output": "AgentFinding",
      "tools": ["gather_findings_summary", "generate_executive_summary", "generate_compliance_report", "export_pdf", "schedule_report"]
    }
  ]
}
